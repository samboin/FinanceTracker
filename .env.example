# Uygulamayı çalıştırmadan önce bu dosyayı .env olarak kopyalayın veya
# IDE Run Configuration / shell export ile bu değişkenleri tanımlayın.
# .env dosyası git'e commit edilmemelidir.

SPRING_PROFILES_ACTIVE=dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=finance_tracker
DB_USERNAME=postgres
DB_PASSWORD=admin
SERVER_PORT=8080
JWT_SECRET=change-this-secret-key-change-this-secret-key-123456
JWT_ACCESS_TOKEN_EXPIRATION_MS=900000
JWT_REFRESH_TOKEN_EXPIRATION_MS=604800000
